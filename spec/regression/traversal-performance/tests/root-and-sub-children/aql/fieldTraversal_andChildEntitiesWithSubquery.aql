LET v_root1 = FIRST((
  FOR v_root2
  IN @@roots
  FILTER (v_root2.`key` == @var1)
  LIMIT @var2
  RETURN v_root2
))
RETURN {
  "Root": (IS_NULL(v_root1) ? null : {
    "predictablePayload": v_root1.`predictablePayload`,
    "children": (
      FOR v_item1
      IN v_root1.`children`[*]
      RETURN {
        "root": {
          "key": v_root1.`key`
        },
        "children": (
          FOR v_item2
          IN v_item1.`children`[*]
          SORT (v_item2.`key`)
          RETURN {
            "key": v_item2.`key`
          }
        )
      }
    )
  })
}

