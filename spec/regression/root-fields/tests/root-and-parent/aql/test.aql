RETURN {
  "allRoots": (
    FOR v_root1
    IN @@roots
    SORT (v_root1.`name`)
    RETURN {
      "name": v_root1.`name`,
      "children": v_root1.`children`[* RETURN {
        "name": CURRENT.`name`,
        "children": CURRENT.`children`[* RETURN {
          "name": CURRENT.`name`,
          "parent": {
            "name": CURRENT.`name`,
            "parent": {
              "name": v_root1.`name`
            },
            "children": CURRENT.`children`[* RETURN {
              "name": CURRENT.`name`,
              "parent": {
                "name": CURRENT.`name`,
                "parent": {
                  "name": v_root1.`name`
                }
              }
            }]
          },
          "root": {
            "name": v_root1.`name`
          }
        }],
        "parent": {
          "name": v_root1.`name`
        },
        "root": {
          "name": v_root1.`name`
        }
      }]
    }
  )
}

