{
  "name": "cruddl",
  "version": "6.0.0-0.organization.0",
  "description": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/cjs/public-api.js",
  "types": "./dist/cjs/public-api.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/public-api.d.ts",
        "default": "./dist/esm/public-api.js"
      },
      "require": {
        "types": "./dist/cjs/public-api.d.ts",
        "default": "./dist/cjs/public-api.js"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/esm/core/public-api.d.ts",
        "default": "./dist/esm/core/public-api.js"
      },
      "require": {
        "types": "./dist/cjs/core/public-api.d.ts",
        "default": "./dist/cjs/core/public-api.js"
      }
    },
    "./arangodb": {
      "import": {
        "types": "./dist/esm/database/arangodb/public-api.d.ts",
        "default": "./dist/esm/database/arangodb/public-api.js"
      },
      "require": {
        "types": "./dist/cjs/database/arangodb/public-api.d.ts",
        "default": "./dist/cjs/database/arangodb/public-api.js"
      }
    },
    "./inmemory": {
      "import": {
        "types": "./dist/esm/database/inmemory/public-api.d.ts",
        "default": "./dist/esm/database/inmemory/public-api.js"
      },
      "require": {
        "types": "./dist/cjs/database/inmemory/public-api.d.ts",
        "default": "./dist/cjs/database/inmemory/public-api.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "./build.sh",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.test.json && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:regression": "vitest run src/testing/regression-tests/regressions.spec.ts",
    "test:regression:in-memory": "CRUDDL_DB=in-memory vitest run src/testing/regression-tests/regressions.spec.ts",
    "test:regression:arango": "CRUDDL_DB=arangodb vitest run src/testing/regression-tests/regressions.spec.ts",
    "test:regression:update": "CRUDDL_DB=arangodb CRUDDL_UPDATE_EXPECTED=true vitest run src/testing/regression-tests/regressions.spec.ts",
    "test:dropdb": "tsx src/testing/regression-tests/drop-test-db.ts",
    "test:perf": "tsx src/testing/performance-tests/run.ts",
    "dev-server": "tsx ./src/dev-server/start.ts",
    "arangodb:start": "arangodb --starter.mode=single --starter.local --starter.port=8528 --starter.data-dir=./db start",
    "arangodb:stop": "arangodb --starter.mode=single --starter.local --starter.port=8528 --starter.data-dir=./db stop",
    "compile-json-schema": "node scripts/compile-json-schema.js",
    "prepare": "husky",
    "knip": "knip",
    "knip:prod": "knip --production"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AEB-labs/cruddl.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "author": "",
  "engines": {
    "npm": ">=6.0.0",
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@apollo/server": "^5.4.0",
    "@graphql-tools/utils": "^8.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.8",
    "@types/pluralize": "0.0.29",
    "@types/stats-lite": "^2.2.2",
    "@vitest/coverage-v8": "^4.0.18",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "cpy-cli": "^4.1.0",
    "express": "^5.2.1",
    "graphql": "^16.6.0",
    "husky": "^9.1.7",
    "knip": "^5.27.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "stats-lite": "^2.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.5.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.31",
    "@js-joda/core": "^5.2.0",
    "ajv": "^8.11.0",
    "ansi-styles": "^5.2.0",
    "arangojs": "^10.0.0",
    "fast-equals": "^6.0.0",
    "graphql-tag": "^2.12.4",
    "jsonc-parser": "^3.3.1",
    "memorize-decorator": "^0.2.2",
    "pluralize": "^8.0.0",
    "tslib": "^2.4.0",
    "yaml": "^2.8.1",
    "yaml-ast-parser": "0.0.43"
  },
  "peerDependencies": {
    "graphql": "^15.0.0 || ^16.0.0"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
