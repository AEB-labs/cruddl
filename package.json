{
  "name": "cruddl",
  "version": "5.0.0",
  "description": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./core": {
      "types": "./dist/cjs/core-exports.d.ts",
      "import": "./dist/esm/core-exports.js",
      "require": "./dist/cjs/core-exports.js"
    },
    "./arangodb": {
      "types": "./dist/cjs/src/database/arangodb/index.d.ts",
      "import": "./dist/esm/src/database/arangodb/index.js",
      "require": "./dist/cjs/src/database/arangodb/index.js"
    },
    "./inmemory": {
      "types": "./dist/cjs/src/database/inmemory/index.d.ts",
      "import": "./dist/esm/src/database/inmemory/index.js",
      "require": "./dist/cjs/src/database/inmemory/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "./build.sh",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.test.json && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dropdb": "tsx ./spec/regression/drop-test-db.ts",
    "test:perf": "tsx ./spec/performance/index.ts",
    "test:coverage": "nyc --reporter=text-summary npm test",
    "test:coverage:full": "nyc --reporter=html npm test",
    "start": "node cruddl",
    "start_arangodb": "arangodb --starter.mode=single --starter.local --starter.port=8528 --starter.data-dir=./db start",
    "stop_arangodb": "arangodb --starter.mode=single --starter.local --starter.port=8528 --starter.data-dir=./db stop",
    "compile-json-schema": "node ./scripts/compile-json-schema.mjs",
    "mrproper": "rimraf dist db node_modules package-lock.json",
    "prepare": "husky",
    "dev": "tsx ./spec/dev/start.mts",
    "knip": "knip",
    "knip:prod": "knip --production"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AEB-labs/cruddl.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "author": "",
  "browser": {
    "@arangodb": false
  },
  "engines": {
    "npm": ">=6.0.0",
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@apollo/server": "^5.4.0",
    "@graphql-tools/utils": "^8.8.0",
    "@types/chai": "^4.3.3",
    "@types/chai-as-promised": "^7.1.5",
    "@types/cors": "^2.8.19",
    "@types/deep-equal-in-any-order": "^1.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.8",
    "@types/pluralize": "0.0.29",
    "@types/stats-lite": "^2.2.2",
    "@types/uuid": "^8.3.4",
    "body-parser": "^1.20.2",
    "chai": "^4.3.6",
    "chai-as-promised": "^7.1.1",
    "cors": "^2.8.5",
    "cpy-cli": "^4.1.0",
    "deep-equal-in-any-order": "^1.1.20",
    "express": "^5.2.1",
    "graphql": "^16.6.0",
    "husky": "^9.1.7",
    "knip": "^5.27.0",
    "lint-staged": "^15.2.10",
    "nyc": "^15.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^3.0.2",
    "stats-lite": "^2.2.0",
    "ts-node": "^10.8.2",
    "tsx": "^4.21.0",
    "typescript": "~5.5.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.31",
    "@js-joda/core": "^5.2.0",
    "ajv": "^8.11.0",
    "ansi-styles": "^5.2.0",
    "arangojs": "^8.1.0",
    "fast-equals": "^6.0.0",
    "json-lint": "^0.1.0",
    "json-source-map": "^0.6.1",
    "memorize-decorator": "^0.2.2",
    "pluralize": "^8.0.0",
    "strip-json-comments": "^3.0.1",
    "tslib": "^2.4.0",
    "uuid": "^8.3.2",
    "yaml": "^2.8.1",
    "yaml-ast-parser": "0.0.43"
  },
  "peerDependencies": {
    "graphql": "^15.0.0 || ^16.0.0"
  },
  "nyc": {
    "include": [
      "src/*.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.d.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "all": true
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
