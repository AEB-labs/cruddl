{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/index.ts!",
    "src/dev-server/*",
    "src/**/*.spec.ts",
    "src/testing/regression-tests/**/test-data.ts"
  ],
  "project": ["src/**/*.ts!", "!**/testing/**!", "!src/project/project-from-fs.ts!"],
  "rules": {
    "exports": "off",
    "types": "off",
    "enumMembers": "off",
    "duplicates": "off"
  },
  "ignoreDependencies": ["@arangodb", "internal", "tslib", "cpy-cli", "@vitest/coverage-v8"],
  "ignoreBinaries": ["arangodb"]
}
