RETURN {
  "vectorSearchArticles": (
    FOR v_article1 IN @@articles
    LET v_vectorScore1 = APPROX_NEAR_COSINE(v_article1.`embedding`, @var1, { nProbe: @var2 })
    SORT v_vectorScore1 DESC
    LIMIT @var3
    RETURN FIRST(
      LET v__vectorScore1 = v_vectorScore1
      RETURN {
        "title": v_article1.`title`,
        "score": v__vectorScore1,
        @var4: v__vectorScore1
      }
    )
  )
}

