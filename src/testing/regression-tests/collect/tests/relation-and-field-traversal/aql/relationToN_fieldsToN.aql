WITH @@deliveries
LET v_shipment1 = FIRST((
  FOR v_shipment2
  IN @@shipments
  FILTER (v_shipment2.`shipmentNumber` == @var1)
  LIMIT @var2
  RETURN v_shipment2
))
RETURN {
  "Shipment": (IS_NULL(v_shipment1) ? null : {
    "allItems": (
      FOR v_root1, v_edge1, v_path1 IN @var3..@var4 OUTBOUND v_shipment1 @@shipments_deliveries
      FILTER v_root1._key != null
      FOR v_item1 IN v_root1.`deliveryContents`[*].`items`[*][** RETURN {
        "itemNumber": CURRENT.`itemNumber`
      }]
      RETURN v_item1
    ),
    @var5: {
      "count": FIRST(
        FOR v_item2
        IN (
          FOR v_root2, v_edge2, v_path2 IN @var6..@var7 OUTBOUND v_shipment1 @@shipments_deliveries
          FILTER v_root2._key != null
          FOR v_item3 IN v_root2.`deliveryContents`[*].`items`[*][**]
          RETURN v_item3
        )
        COLLECT WITH COUNT INTO v_count1
        RETURN v_count1
      )
    },
    "allDeliveryContents": (
      FOR v_root3, v_edge3, v_path3 IN @var8..@var9 OUTBOUND v_shipment1 @@shipments_deliveries
      FILTER v_root3._key != null
      FOR v_item4 IN v_root3.`deliveryContents`[* RETURN {
        "deliveryContentNumber": CURRENT.`deliveryContentNumber`
      }]
      RETURN v_item4
    ),
    @var10: {
      "count": FIRST(
        FOR v_item5
        IN (
          FOR v_root4, v_edge4, v_path4 IN @var11..@var12 OUTBOUND v_shipment1 @@shipments_deliveries
          FILTER v_root4._key != null
          FOR v_item6 IN v_root4.`deliveryContents`[*]
          RETURN v_item6
        )
        COLLECT WITH COUNT INTO v_count2
        RETURN v_count2
      )
    }
  })
}

