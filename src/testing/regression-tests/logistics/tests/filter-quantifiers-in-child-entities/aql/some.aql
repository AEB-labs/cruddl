RETURN {
  "allDeliveries": (
    FOR v_delivery1
    IN @@deliveries
    SORT (v_delivery1.`deliveryNumber`)
    RETURN {
      "items": v_delivery1.`items`[* FILTER (CURRENT.`notes`[*].`priority` ANY > @var1) RETURN {
        "itemNumber": CURRENT.`itemNumber`,
        "notes": CURRENT.`notes`[* RETURN {
          "text": CURRENT.`text`,
          "priority": CURRENT.`priority`
        }]
      }]
    }
  )
}

